{"schema_version": "1.0.0", "model_version": "0.1.0", "discipline_id": "intl-philosophy-of-technology", "display_names": {"ru": "Philosophy of technology (международная)", "en": "Philosophy of technology"}, "region": "international", "aliases": ["philtech", "phil tech"], "source_status": "llm_draft", "evidence_refs": [{"source_type": "llm_pretraining"}], "paradigm": "Philosophy of technology as a distinct subfield analyzing technology's essence, mediating role, and normative implications. Heidegger-Ellul foundational layer; contemporary empirical turn (Verbeek, Vermaas) and postphenomenology (Ihde).", "epistemic_regime": "Conceptual analysis, phenomenological description of technological mediation, normative argumentation. Empirical case studies are illustrative but not the primary epistemic mode.", "forms_of_evidence": ["conceptual analysis", "phenomenological description", "case study of mediating artifacts", "normative argumentation", "critical commentary"], "canonical_questions": ["What is the essence of modern technology?", "How do artifacts mediate human action and perception?", "Can we distinguish good from bad technology normatively?", "What is the relation between technology and form of life?"], "typical_problem_forms": ["tension between technological autonomy and human agency", "inadequacy of pure-instrument account of technology", "mismatch between empirical reality of artifacts and philosophical generalizations"], "legitimate_objects": ["technology as such", "technical artifact", "mediation", "sociotechnical assemblage", "postphenomenological relation"], "illegitimate_or_borderline_objects": ["engineering design decisions (engineering studies)", "quantitative user research (HCI)", "platform business models (innovation studies)"], "argument_styles": ["conceptual analysis", "phenomenological description", "postphenomenological description", "normative argumentation"], "publication_genres": ["theoretical essay", "conceptual article", "book chapter", "systematic review", "commentary"], "institutional_forms": ["philosophy departments", "STS programs", "4S society", "SPT (Society for Philosophy and Technology)"], "international_mapping": ["ru-philosophy-of-technology"], "methods": ["conceptual analysis", "postphenomenological analysis", "critical analysis"], "instruments": ["mediation analysis", "multistability description", "amplification/reduction framework"], "ontologies": ["Gestell", "mediation", "postphenomenological relation", "sociotechnical assemblage"], "key_authors": [{"name": "Martin Heidegger", "role": "founder", "era": "20th c.", "discipline_relevance": "Foundational question of essence of modern technology."}, {"name": "Don Ihde", "role": "classic", "era": "20th–21st c.", "discipline_relevance": "Postphenomenology founder."}, {"name": "Peter-Paul Verbeek", "role": "contemporary", "discipline_relevance": "Mediation theory and moralizing technology."}, {"name": "Andrew Feenberg", "role": "contemporary", "discipline_relevance": "Critical theory of technology."}], "history": "Heidegger 1954. Ellul mid-century. Postphenomenological turn from Ihde 1990s onward. Empirical turn 2000s (Verbeek et al.).", "boundaries": "Distinct from STS (social-scientific) and engineering ethics (applied normative). Postphenomenology is one school among others.", "adjacent": ["intl-sts", "intl-philosophy-of-ai", "intl-philosophy-of-mind"], "times_seen": 0, "last_updated": "2026-06-17"}
