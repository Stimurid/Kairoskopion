# Kairoskopion environment variables
# Copy to .env and fill in values as needed.
# Do NOT commit .env with real secrets.

# Registry storage directory (default: ./registry)
KAIRON_REGISTRY_DIR=./registry

# Vault output directory for markdown cards (default: ./vault)
KAIRON_VAULT_DIR=./vault

# =============================================================================
# LLM configuration
# Aligned with litops/quint pattern: KAIROSKOPION_LLM_* (primary) → LLM_* (fallback)
# =============================================================================

# Provider mode: "openai_compatible" or "none"
KAIROSKOPION_LLM_PROVIDER=openai_compatible

# Model name (required for LLM to activate)
KAIROSKOPION_LLM_MODEL=gpt-4.1-mini

# API endpoint — any OpenAI-compatible server
# 302.ai (default, shared with quint/litops):
KAIROSKOPION_LLM_BASE_URL=https://api.302.ai/v1
# OpenAI direct:
# KAIROSKOPION_LLM_BASE_URL=https://api.openai.com/v1
# Local (Ollama, vLLM, llama.cpp):
# KAIROSKOPION_LLM_BASE_URL=http://localhost:11434/v1

# API key (or use LLM_API_KEY as shared fallback with litops)
KAIROSKOPION_LLM_API_KEY=sk-your-key-here

# Optional: env var name containing the key (default: KAIROSKOPION_LLM_API_KEY)
# KAIROSKOPION_LLM_API_KEY_ENV=LLM_API_KEY

# Optional: request timeout in milliseconds (default: 30000)
# KAIROSKOPION_LLM_TIMEOUT_MS=30000

# =============================================================================
# External adapters
# =============================================================================
# OPENALEX_EMAIL=
# CROSSREF_MAILTO=
# LITOPS_VAULT_PATH=
# WHITECROW_FIELD_PATH=

# =============================================================================
# Auth/proxy zero-cost improvements (docs/AUTH_AND_PROXY_API_LANDSCAPE.md §6)
# All OPTIONAL. None required for the system to work. Do NOT commit real values.
# =============================================================================
# OpenAlex polite-pool: appended as ?mailto=... — ~10x rate-limit headroom
# KAIROSKOPION_OPENALEX_MAILTO=you@example.org
# Crossref polite-pool: same trick
# KAIROSKOPION_CROSSREF_MAILTO=you@example.org
# Semantic Scholar API key (free signup): 10x rate limit
# KAIROSKOPION_SEMANTIC_SCHOLAR_API_KEY=
# ORCID Public API OAuth client credentials (free signup)
# KAIROSKOPION_ORCID_CLIENT_ID=
# KAIROSKOPION_ORCID_CLIENT_SECRET=
# CORE API key (free academic tier)
# KAIROSKOPION_CORE_API_KEY=
